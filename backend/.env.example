# =============================================================================
# Startup CRM Lite — Backend Environment Variables
# =============================================================================
#
# HOW TO USE THIS FILE:
#   For local development: copy this file to .env and fill in your values.
#   For Railway deployment: set each variable in Railway dashboard manually.
#   NEVER commit your actual .env file — it is gitignored for security.
#
# =============================================================================

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
# Railway automatically injects PORT — do NOT set this in Railway dashboard.
# For local development only:
PORT=5000

# ---------------------------------------------------------------------------
# MONGODB ATLAS
# ---------------------------------------------------------------------------
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appname>
#
# IMPORTANT — MongoDB Atlas Network Access:
#   Go to Atlas → Network Access → Add IP Address → 0.0.0.0/0 (allow from anywhere)
#   Railway uses dynamic IPs, so wildcard access is required.
#
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/startup-crm-lite?appName=startupcrmlite

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum recommended: 64 random hex characters
#
JWT_SECRET=your_very_long_random_jwt_secret_key_minimum_64_chars
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# ENVIRONMENT
# ---------------------------------------------------------------------------
# LOCAL:   NODE_ENV=development
# RAILWAY: NODE_ENV=production
#
NODE_ENV=development

# ---------------------------------------------------------------------------
# CORS — Frontend URL
# ---------------------------------------------------------------------------
# LOCAL:   FRONTEND_URL=http://localhost:5173
# RAILWAY: FRONTEND_URL=https://<your-app>.vercel.app
#
# Supports comma-separated values for multiple frontends:
#   FRONTEND_URL=https://app.vercel.app,https://staging.vercel.app
#
FRONTEND_URL=http://localhost:5173

# =============================================================================
# RAILWAY DASHBOARD CHECKLIST (set all of these in Railway → Variables tab)
# =============================================================================
# [ ] MONGODB_URI   = mongodb+srv://...  (your Atlas connection string)
# [ ] JWT_SECRET    = <64+ char random hex>
# [ ] JWT_EXPIRES_IN = 7d
# [ ] NODE_ENV      = production
# [ ] FRONTEND_URL  = https://<your-app>.vercel.app
# Note: Do NOT set PORT — Railway manages this automatically.
# =============================================================================
